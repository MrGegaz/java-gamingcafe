<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Main container-->

<BorderPane fx:id="mainLayout" styleClass="main-container" stylesheets="@../css/global.css"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gamingcafe.controller.MainController">

   <!-- Left Menu -->
   <left>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <Label styleClass="sidebar-title" text="GAMING CAFE" />
         <Button styleClass="nav-button" text="Radne Stanice" />
         <Button styleClass="nav-button" text="Korisnici" />
         <Region VBox.vgrow="ALWAYS" /> <!-- Push bottom elements to the bottom -->
         <Button styleClass="nav-button" text="Postavke" />
      </VBox>
   </left>

   <!-- Central content container-->
   <center>
      <VBox spacing="20" style="-fx-padding: 20;">
         <Label text="Pregled Radnih Stanica" styleClass="section-header"/>
         <TableView fx:id="workstationTable" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
               <TableColumn fx:id="nameColumn" text="Naziv" prefWidth="150" />
               <TableColumn fx:id="typeColumn" text="Tip" prefWidth="100" />
               <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
            </columns>
         </TableView>
      </VBox>
   </center>

</BorderPane>
