<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="mainLayout" prefWidth="1200" prefHeight="720"
            stylesheets="@../css/global.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gamingcafe.controller.MainController">

    <!-- TOP: Header -->
    <top>
        <HBox styleClass="app-header" alignment="CENTER">
            <VBox alignment="CENTER" spacing="4">
                <Label text="GAMING CAFE" styleClass="header-title" />
                <Label text="MANAGEMENT SYSTEM" styleClass="header-subtitle" />
            </VBox>
        </HBox>
    </top>

    <!-- LEFT: Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <!-- Logo area -->
            <VBox styleClass="sidebar-logo-area" alignment="CENTER" spacing="8">
                <FontIcon iconLiteral="mdi2l-lightning-bolt" iconSize="36" styleClass="sidebar-icon" />
                <Label text="GAMING CAFE" styleClass="sidebar-logo-label" />
            </VBox>

            <!-- Nav items -->
            <Button text="POČETNA" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="mdi2h-home" iconSize="18" /></graphic>
            </Button>
            <Button text="RAČUNALA" styleClass="nav-button-active" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" fx:id="navWorkstations">
                <graphic><FontIcon iconLiteral="mdi2m-monitor" iconSize="18" /></graphic>
            </Button>
            <Button text="REZERVACIJE" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="mdi2c-calendar" iconSize="18" /></graphic>
            </Button>
            <Button text="ČLANOVI" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="mdi2a-account-multiple" iconSize="18" /></graphic>
            </Button>
            <Button text="PONUDA" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="mdi2g-gamepad" iconSize="18" /></graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <Button text="POSTAVKE" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="mdi2c-cog" iconSize="18" /></graphic>
            </Button>

            <!-- Status at bottom of sidebar -->
            <VBox styleClass="sidebar-status">
                <Label fx:id="sidebarStatus" text="● Spojen na bazu" styleClass="status-text-green" />
            </VBox>
        </VBox>
    </left>

    <!-- CENTER: Content area + Detail panel -->
    <center>
        <BorderPane>

            <!-- Main content -->
            <center>
                <VBox styleClass="content-area" spacing="15">
                    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>

                    <Label text="RAČUNALA" styleClass="section-title" />

                    <!-- Action toolbar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="NOVO RAČUNALO" styleClass="action-button-green" fx:id="btnNew" />
                        <Button text="UREDI" styleClass="action-button" fx:id="btnEdit" />
                        <Button text="OBRIŠI" styleClass="action-button" fx:id="btnDelete" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" promptText="Pretraži..." prefWidth="200" />
                    </HBox>

                    <!-- Workstation table -->
                    <TableView fx:id="workstationTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
                            <TableColumn fx:id="nameColumn" text="Naziv" prefWidth="150" />
                            <TableColumn fx:id="typeColumn" text="Tip" prefWidth="120" />
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                            <TableColumn fx:id="priceColumn" text="Cijena/h" prefWidth="90" />
                        </columns>
                    </TableView>
                </VBox>
            </center>

            <!-- Detail panel -->
            <right>
                <VBox styleClass="detail-panel" spacing="10" minWidth="220" prefWidth="250">
                    <padding><Insets top="20" right="15" bottom="20" left="15" /></padding>

                    <Label text="DETALJI RAČUNALA:" styleClass="detail-header" />
                    <Label fx:id="detailTitle" text="—" styleClass="detail-title" />

                    <Label text="Naziv:" styleClass="form-label" />
                    <TextField fx:id="detailName" maxWidth="Infinity" />

                    <Label text="Tip:" styleClass="form-label" />
                    <ComboBox fx:id="detailType" maxWidth="Infinity" />

                    <Label text="Status:" styleClass="form-label" />
                    <ComboBox fx:id="detailStatus" maxWidth="Infinity" />

                    <Label text="Cijena/h:" styleClass="form-label" />
                    <TextField fx:id="detailPrice" maxWidth="Infinity" />

                    <Region VBox.vgrow="ALWAYS" />

                    <Button fx:id="btnSave" text="SPREMI" styleClass="save-button" maxWidth="Infinity" />
                    <Button fx:id="btnCancel" text="ODUSTANI" styleClass="cancel-button" maxWidth="Infinity" />
                </VBox>
            </right>

        </BorderPane>
    </center>

</BorderPane>
