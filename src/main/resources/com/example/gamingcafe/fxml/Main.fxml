<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="mainLayout" prefWidth="1200" prefHeight="720"
            stylesheets="@../css/global.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gamingcafe.controller.MainController">

    <!-- TOP: Header -->
    <top>
        <HBox styleClass="app-header" alignment="CENTER">
            <VBox alignment="CENTER" spacing="4">
                <Label text="GAMING CAFE" styleClass="header-title" />
                <Label text="MANAGEMENT SYSTEM" styleClass="header-subtitle" />
            </VBox>
        </HBox>
    </top>

    <!-- LEFT: Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <!-- Logo area -->
            <VBox styleClass="sidebar-logo-area" alignment="CENTER" spacing="8">
                <FontIcon iconLiteral="mdi2l-lightning-bolt" iconSize="36" styleClass="sidebar-icon" />
                <Label text="GAMING CAFE" styleClass="sidebar-logo-label" />
            </VBox>

            <!-- Nav items -->
            <Button fx:id="navMain" text="POČETNA" styleClass="nav-button-active" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" onAction="#onNavMain">
                <graphic><FontIcon iconLiteral="mdi2h-home" iconSize="18" /></graphic>
            </Button>
            <Button fx:id="navWorkstations" text="RAČUNALA" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" onAction="#onNavWorkstations">
                <graphic><FontIcon iconLiteral="mdi2m-monitor" iconSize="18" /></graphic>
            </Button>
            <Button fx:id="navReservation" text="REZERVACIJE" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" disable="true">
                <graphic><FontIcon iconLiteral="mdi2c-calendar" iconSize="18" /></graphic>
            </Button>
            <Button fx:id="navClients" text="ČLANOVI" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" disable="true">
                <graphic><FontIcon iconLiteral="mdi2a-account-multiple" iconSize="18" /></graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="navSettings" text="POSTAVKE" styleClass="nav-button" maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="12" disable="true">
                <graphic><FontIcon iconLiteral="mdi2c-cog" iconSize="18" /></graphic>
            </Button>

            <!-- Status at bottom of sidebar -->
            <VBox styleClass="sidebar-status">
                <Label fx:id="sidebarStatus" text="● Spojen na bazu" styleClass="status-text-green" />
            </VBox>
        </VBox>
    </left>

    <!-- CENTER: Content area + Detail panel -->
    <center>
        <BorderPane fx:id="contentArea">

        </BorderPane>
    </center>

</BorderPane>
